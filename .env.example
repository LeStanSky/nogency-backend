# App Configuration
NODE_ENV=development
PORT=8000

# Database (Supabase PostgreSQL)
# Use Session Pooler for better compatibility (IPv4)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI Integration
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email Service
RESEND_API_KEY=re_xxx

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-change-this-in-production
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Rate Limiting (optional - defaults shown)
# RATE_LIMIT_MAX=100                    # Max requests per window (global)
# RATE_LIMIT_TIME_WINDOW=1 minute       # Time window for rate limiting
# RATE_LIMIT_AUTH_MAX=10                # Max requests for auth endpoints (stricter)
# RATE_LIMIT_AUTH_TIME_WINDOW=1 minute  # Time window for auth rate limiting

# Sentry (optional)
SENTRY_DSN=https://xxx@sentry.io/xxx
