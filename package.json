{
  "name": "nogency-api",
  "version": "1.0.0",
  "description": "NoGency AI - Backend API for rental property management with AI-powered tenant screening",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release": "npm run build && npm run test:coverage && npm version patch",
    "prepare": "husky"
  },
  "keywords": [
    "rental",
    "property-management",
    "ai",
    "tenant-screening",
    "fastify",
    "typescript"
  ],
  "author": "Stas",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.39.7",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.5",
    "pdfkit": "^0.14.0",
    "resend": "^3.2.0",
    "stripe": "^14.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vitest/coverage-v8": "^1.2.2",
    "@vitest/ui": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-google": "^0.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.4",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
